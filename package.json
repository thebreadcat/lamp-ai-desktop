{
  "name": "lamp-desktop",
  "version": "0.2.1",
  "description": "Desktop launcher for Lamp AI — macOS, Windows, Linux",
  "author": "thebreadcat <brockmcblockchain@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "ensure-lamp": "python3 scripts/ensure-lamp.py",
    "icons": "bash scripts/generate-icons.sh",
    "bundle-python": "node scripts/bundle-python.mjs",
    "predist": "npm run ensure-lamp && npm run icons && npm run bundle-python",
    "dev": "node scripts/dev.mjs",
    "start": "electron .",
    "build": "npm run predist && electron-builder",
    "build:mac": "npm run predist && electron-builder --mac",
    "build:win": "npm run predist && electron-builder --win",
    "build:linux": "npm run predist && electron-builder --linux",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "ai.lamp.desktop",
    "productName": "Lamp",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "scripts/**/*",
      "setup/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "lamp",
        "to": "lamp",
        "filter": [
          "**/*",
          "!**/.git/**",
          "!**/.git"
        ]
      },
      {
        "from": "resources/python",
        "to": "python",
        "filter": ["**/*"]
      },
      {
        "from": "build/icon.png",
        "to": "app-icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/icons",
        "to": "icons",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"],
      "icon": "build/icon.icns",
      "identity": "-",
      "gatekeeperAssess": false,
      "hardenedRuntime": false
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Utility",
      "icon": "build/icons"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "deb": {
      "depends": []
    }
  }
}
